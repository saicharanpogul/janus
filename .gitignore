target/
**/*.rs.bk
.DS_Store
.vscode/
.idea/
node_modules/
.env
.env.local
*.so
test-ledger/
# SDK build artifacts
sdk/dist/
sdk/*.tsbuildinfo
# Local Solana keypairs / wallets — never commit
*-keypair.json
*.kp
# QEDGen-bundled Lean library + Lake build artefacts — regenerable from
# `qedgen codegen` so we don't commit the multi-MB tree to history.
formal_verification/*/.lake/
formal_verification/*/build/
# lakefile.lean, lean-toolchain, AND lean_solana/ ARE committed.
# lean_solana is the QEDGen Solana support library (~550K per program,
# 5 copies = 2.7MB total). CI needs it to satisfy the `qedgenSupport`
# package dependency in each lakefile. Regenerable via `qedgen init`.
lake-manifest.json
.qed/

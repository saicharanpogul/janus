target/
**/*.rs.bk
.DS_Store
.vscode/
.idea/
node_modules/
.env
.env.local
*.so
test-ledger/
# SDK build artifacts
sdk/dist/
sdk/*.tsbuildinfo
# Local Solana keypairs / wallets — never commit
*-keypair.json
*.kp
# QEDGen-bundled Lean library + Lake build artefacts — regenerable from
# `qedgen codegen` so we don't commit the multi-MB tree to history.
formal_verification/*/.lake/
formal_verification/*/build/
# lakefile.lean, lean-toolchain, lean_solana/, and lean_solana_mathlib/
# ARE committed. They're the QEDGen support libraries needed by each
# project's `require qedgenSupport` / `require qedgenSupportMathlib`
# in lakefile.lean. Small (~3MB total across all programs);
# regenerable via `qedgen init`.
lake-manifest.json
.qed/
